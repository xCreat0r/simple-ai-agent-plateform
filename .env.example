# 数据库
# 本地: postgres://postgres:postgres@localhost:5432/agent_platform
# 生产: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/agent_platform?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_platform

# AI 服务
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
SERPAPI_API_KEY=your-serpapi-key
# SERPAPI_PROXY=http://127.0.0.1:7890   # 可选，本地代理地址
BAILIAN_API_KEY=sk-your-bailian-key

# Auth 服务
# 生成方式: openssl rand -base64 32
BETTER_AUTH_SECRET=
# 本地: http://localhost:3000
# 生产: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000

# 初始化管理员账号（可选，仅 db:seed 使用）
# SEED_EMAIL=admin@example.com
# SEED_PASSWORD=changeme123
# SEED_NAME=管理员
